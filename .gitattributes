# Auto detect text files and perform LF normalization
* text=auto

# Python source
*.py text eol=lf

# TypeScript / JavaScript / JSX / TSX
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
