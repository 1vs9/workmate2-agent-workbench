# WorkBuddy fork image for PawBench (optional).
# Build from PawBench repo root:
#   docker build -f /path/to/workbuddy/eval/pawbench/Dockerfile.workbuddy \
#     --build-arg WORKBUDDY_SRC=/path/to/workbuddy \
#     -t qwenclawbench-workbuddy:latest .
#
# Then: python run_bench.py --docker-image qwenclawbench-workbuddy:latest ...

FROM python:3.11-slim

ARG WORKBUDDY_SRC
ARG NODE_MAJOR=20

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    python3 python3-pip git curl wget ca-certificates gnupg \
    build-essential libssl-dev jq sqlite3 \
    xvfb xfce4 dbus dbus-x11 scrot \
    fonts-wqy-zenhei fonts-wqy-microhei \
    chromium chromium-sandbox \
    libx11-xcb1 libxcomposite1 libxdamage1 libxext6 libxfixes3 \
    libxi6 libxtst6 libnss3 libglib2.0-0 libdrm2 libgbm1 libasound2 \
    fonts-liberation && \
    rm -rf /var/lib/apt/lists/*

ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV COPAW_RUNNING_IN_CONTAINER=1

COPY pawbench/ /opt/copawbench/pawbench/
COPY run_bench.py /opt/copawbench/run_bench.py
COPY requirements.txt /opt/copawbench/requirements.txt

# Install WorkBuddy (qwenpaw) from host build context
COPY workbuddy-src /tmp/workbuddy-src
RUN pip install --no-cache-dir /tmp/workbuddy-src && rm -rf /tmp/workbuddy-src

RUN pip install --no-cache-dir -r /opt/copawbench/requirements.txt
ENV PYTHONPATH=/opt/copawbench

RUN mkdir -p /app/working/workspaces/default/output
